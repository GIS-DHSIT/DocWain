{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.5",
  "body": [
    {
      "type": "ColumnSet",
      "columns": [
        {
          "type": "Column",
          "width": "auto",
          "items": [
            {
              "type": "TextBlock",
              "text": "{step_indicator}",
              "weight": "Bolder",
              "size": "Medium",
              "color": "Accent"
            }
          ]
        },
        {
          "type": "Column",
          "width": "stretch",
          "items": [
            {
              "type": "TextBlock",
              "text": "{stage_title}",
              "weight": "Bolder",
              "size": "Medium"
            },
            {
              "type": "TextBlock",
              "text": "{stage_detail}",
              "wrap": true,
              "size": "Small",
              "isSubtle": true,
              "spacing": "None"
            }
          ]
        }
      ]
    },
    {
      "type": "TextBlock",
      "text": "{progress_bar}",
      "fontType": "Monospace",
      "size": "Small",
      "spacing": "Small"
    }
  ]
}
