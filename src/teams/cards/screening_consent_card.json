{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.5",
  "body": [
    {
      "type": "TextBlock",
      "text": "Security Screening: ATTENTION",
      "weight": "Bolder",
      "size": "Medium",
      "color": "Attention"
    },
    {
      "type": "ColumnSet",
      "columns": [
        {
          "type": "Column",
          "width": "auto",
          "items": [
            {
              "type": "TextBlock",
              "text": "Risk: {risk_level}",
              "weight": "Bolder",
              "color": "Attention"
            }
          ]
        },
        {
          "type": "Column",
          "width": "stretch",
          "items": [
            {
              "type": "TextBlock",
              "text": "({risk_score})",
              "isSubtle": true
            }
          ]
        }
      ]
    },
    {
      "type": "TextBlock",
      "text": "Findings:",
      "weight": "Bolder",
      "size": "Small",
      "spacing": "Medium"
    },
    {
      "type": "TextBlock",
      "text": "{findings_text}",
      "wrap": true,
      "size": "Small"
    }
  ],
  "actions": [
    {
      "type": "Action.Submit",
      "title": "Proceed Anyway",
      "style": "positive",
      "data": { "action": "pipeline_consent_proceed", "document_id": "{document_id}" }
    },
    {
      "type": "Action.Submit",
      "title": "Cancel Embedding",
      "style": "destructive",
      "data": { "action": "pipeline_consent_reject", "document_id": "{document_id}" }
    }
  ]
}
