{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.5",
  "body": [
    {
      "type": "TextBlock",
      "text": "Security Screening Report",
      "weight": "Bolder",
      "size": "Medium"
    },
    {
      "type": "ColumnSet",
      "columns": [
        {
          "type": "Column",
          "width": "auto",
          "items": [
            {
              "type": "TextBlock",
              "text": "Risk Level:",
              "weight": "Bolder"
            }
          ]
        },
        {
          "type": "Column",
          "width": "stretch",
          "items": [
            {
              "type": "TextBlock",
              "text": "{risk_level}",
              "color": "{risk_color}"
            }
          ]
        },
        {
          "type": "Column",
          "width": "auto",
          "items": [
            {
              "type": "TextBlock",
              "text": "Score: {overall_score}",
              "isSubtle": true
            }
          ]
        }
      ]
    },
    {
      "type": "TextBlock",
      "text": "Files screened: {filenames}",
      "wrap": true,
      "isSubtle": true,
      "size": "Small"
    },
    {
      "type": "TextBlock",
      "text": "{findings_text}",
      "wrap": true,
      "separator": true
    },
    {
      "type": "TextBlock",
      "text": "{tools_summary}",
      "isSubtle": true,
      "size": "Small"
    }
  ]
}
