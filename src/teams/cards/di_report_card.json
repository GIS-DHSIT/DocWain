{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.5",
  "body": [
    {
      "type": "ColumnSet",
      "columns": [
        {
          "type": "Column",
          "width": "stretch",
          "items": [
            {
              "type": "TextBlock",
              "text": "Document Analyzed",
              "weight": "Bolder",
              "size": "Medium",
              "color": "Accent"
            }
          ]
        },
        {
          "type": "Column",
          "width": "auto",
          "items": [
            {
              "type": "TextBlock",
              "text": "{domain_badge}",
              "weight": "Bolder",
              "size": "Small",
              "color": "Accent"
            }
          ],
          "verticalContentAlignment": "Center"
        }
      ]
    },
    {
      "type": "TextBlock",
      "text": "{summary_text}",
      "wrap": true,
      "spacing": "Small"
    },
    {
      "type": "Container",
      "separator": true,
      "spacing": "Medium",
      "items": [
        {
          "type": "TextBlock",
          "text": "Key Insights",
          "weight": "Bolder",
          "size": "Small",
          "color": "Accent"
        },
        {
          "type": "TextBlock",
          "text": "{insights_text}",
          "wrap": true,
          "size": "Small"
        }
      ]
    },
    {
      "type": "ColumnSet",
      "separator": true,
      "spacing": "Small",
      "columns": [
        {
          "type": "Column",
          "width": "stretch",
          "items": [
            {
              "type": "TextBlock",
              "text": "{security_text}",
              "size": "Small",
              "isSubtle": true
            }
          ]
        },
        {
          "type": "Column",
          "width": "auto",
          "items": [
            {
              "type": "TextBlock",
              "text": "{metadata_text}",
              "size": "Small",
              "isSubtle": true
            }
          ]
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "Action.Submit",
      "title": "{action1_title}",
      "data": { "action": "domain_query", "query": "{action1_query}" }
    },
    {
      "type": "Action.Submit",
      "title": "{action2_title}",
      "data": { "action": "domain_query", "query": "{action2_query}" }
    },
    {
      "type": "Action.Submit",
      "title": "{action3_title}",
      "data": { "action": "domain_query", "query": "{action3_query}" }
    }
  ]
}
