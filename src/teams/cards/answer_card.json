{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.5",
  "body": [
    {
      "type": "ColumnSet",
      "columns": [
        {
          "type": "Column",
          "width": "stretch",
          "items": [
            {
              "type": "TextBlock",
              "text": "{title}",
              "size": "Medium",
              "weight": "Bolder",
              "wrap": true
            }
          ]
        },
        {
          "type": "Column",
          "width": "auto",
          "items": [
            {
              "type": "TextBlock",
              "text": "{domain_badge}",
              "weight": "Bolder",
              "size": "Small",
              "color": "Accent"
            }
          ],
          "verticalContentAlignment": "Center"
        }
      ]
    },
    {
      "type": "TextBlock",
      "text": "{confidence_text}",
      "size": "Small",
      "isSubtle": true,
      "spacing": "None"
    },
    {
      "type": "TextBlock",
      "text": "{text}",
      "wrap": true,
      "spacing": "Small"
    },
    {
      "type": "Container",
      "id": "sourcesContainer",
      "isVisible": false,
      "separator": true,
      "items": [
        {
          "type": "TextBlock",
          "text": "Sources",
          "weight": "Bolder",
          "size": "Small",
          "isSubtle": true
        },
        {
          "type": "TextBlock",
          "text": "{sources_text}",
          "wrap": true,
          "size": "Small",
          "isSubtle": true
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "Action.ToggleVisibility",
      "title": "{sources_toggle_title}",
      "targetElements": ["sourcesContainer"]
    },
    {
      "type": "Action.Submit",
      "title": "Tools",
      "data": { "action": "show_tools" }
    }
  ]
}
