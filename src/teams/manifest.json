  ],
  "webApplicationInfo": {
    "id": "fd5d5c9d-12b9-441f-b72f-4e94a50da1af",
    "resource": "api://http://4.213.139.185:8000/teams/messages/botid-00000000-0000-0000-0000-000000000000"
