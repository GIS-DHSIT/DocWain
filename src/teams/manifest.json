  "packageName": "com.docwain.bot",
  "name": {
    "short": "DocWain",
    "full": "DocWain Assistant"
  },
  "description": {
    "short": "Ask DocWain questions from Microsoft Teams.",
    "full": "Upload files in Teams, DocWain ingests them automatically, and you can chat or run tools (summaries, extraction, model/persona switch) right away. Configure the messaging endpoint to point at /teams/messages."
  },
  "accentColor": "#004578",
  "icons": {
    "color": "color.png",
    "outline": "outline.png"
  },
  "bots": [
    {
      "botId": "fd5d5c9d-12b9-441f-b72f-4e94a50da1af",
      "scopes": [
        "personal"
      ],
      "supportsFiles": true,
      "isNotificationOnly": false,
      "commandLists": [
        {
          "scopes": [
            "personal"
          ],
          "commands": [
            {
              "title": "Ask",
              "description": "Ask DocWain a question"
            },
            {
              "title": "Help",
              "description": "Get usage tips"
            },
            {
              "title": "Tools",
              "description": "Show DocWain tools for this chat"
            }
          ]
        }
      ]
    }
  ],
  "staticTabs": [
