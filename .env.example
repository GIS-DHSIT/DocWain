# DocWain Configuration Template
# Copy this file to .env and fill in your values

# =============================================================================
# API KEYS
# =============================================================================
GROQ_API_KEY=your-groq-api-key
GEMINI_API_KEY=your-gemini-api-key
ENCRYPTION_KEY=your-encryption-key

# =============================================================================
# MONGODB
# =============================================================================
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true
MONGODB_FALLBACK_URI=mongodb://localhost:27017
MONGODB_DB=docwain
MONGODB_DOCUMENTS_COLLECTION=documents
MONGODB_PROFILES_COLLECTION=profiles
MONGODB_SUBSCRIPTIONS_COLLECTION=subscriptions

# =============================================================================
# QDRANT VECTOR DATABASE
# =============================================================================
QDRANT_URL=https://your-cluster.region.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_TIMEOUT=120

# =============================================================================
# REDIS CACHE
# =============================================================================
REDIS_HOST=your-redis.redis.cache.windows.net
REDIS_PORT=6380
REDIS_PASSWORD=your-redis-password
REDIS_SSL=true
REDIS_DB=0
REDIS_CONNECTION_STRING=your-redis-host:6380,password=your-password,ssl=True,abortConnect=False

# =============================================================================
# NEO4J KNOWLEDGE GRAPH
# =============================================================================
NEO4J_URI=neo4j://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password
NEO4J_DATABASE=neo4j
KG_ENABLED=false

# =============================================================================
# AWS (Chat History Storage)
# =============================================================================
AWS_ACCESS_KEY=your-aws-access-key
AWS_SECRET_KEY=your-aws-secret-key
AWS_REGION=eu-west-2
AWS_BUCKET_NAME=docwain-chat-history

# =============================================================================
# AZURE AI / VISION
# =============================================================================
AZURE_SUBSCRIPTION_ID=your-azure-subscription-id
AZURE_RESOURCE_GROUP=rg-docwain-dev
AZURE_PROJECT_NAME=dhs-ai-competency
AZURE_AI_ENDPOINT=https://your-resource.services.ai.azure.com/api/projects/your-project
AZURE_AI_KEY=your-azure-ai-key

# =============================================================================
# AZURE OPENAI (Cloud LLM)
# =============================================================================
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_DEPLOYMENT=gpt-4.1
AZURE_OPENAI_API_VERSION=2024-05-01-preview
DOCWAIN_CLOUD_LLM_ENABLED=false

# =============================================================================
# AZURE GPT-4o
# =============================================================================
AZUREGPT4O_ENDPOINT=https://your-openai-resource.openai.azure.com/
AZUREGPT4O_DEPLOYMENT=your-deployment-name
AZUREGPT4O_API_KEY=your-azure-gpt4o-key
AZUREGPT4O_VERSION=2024-05-01-preview

# =============================================================================
# AZURE BLOB STORAGE
# =============================================================================
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
AZURE_BLOB_KEY=your-blob-key
AZURE_BLOB_ACCOUNT_NAME=docwainuploads
AZURE_BLOB_CONTAINER_NAME=document-content

# =============================================================================
# MICROSOFT TEAMS BOT (Single-Tenant)
# =============================================================================
MICROSOFT_APP_ID=your-bot-app-id
MICROSOFT_APP_PASSWORD=your-app-password
MICROSOFT_APP_TENANT_ID=your-tenant-id
MICROSOFT_APP_TYPE=SingleTenant
TEAMS_SHARED_SECRET=
TEAMS_SIGNATURE_ENABLED=false
TEAMS_DEFAULT_PROFILE=default
TEAMS_DEFAULT_MODEL=DocWain-Agent
TEAMS_DEFAULT_PERSONA=Document Assistant
TEAMS_SESSION_AS_SUBSCRIPTION=true
TEAMS_PROFILE_PER_USER=true
TEAMS_MAX_ATTACHMENT_MB=50
TEAMS_HTTP_TIMEOUT_SEC=20
TEAMS_HTTP_RETRIES=2
TEAMS_BOT_ACCESS_TOKEN=
TEAMS_BLOB_CONTAINER=local-uploads
TEAMS_BLOB_PATH_PREFIX=teams
TEAMS_DIAG_MODE=false
DOCWAIN_WEB_URL=https://www.docwain.ai

# =============================================================================
# OLLAMA CLOUD (Response Generation — primary LLM)
# =============================================================================
OLLAMA_HOST=https://ollama.com
OLLAMA_CLOUD_MODEL=qwen3.5:397b
OLLAMA_MODEL=qwen3.5:397b
OLLAMA_API=your-ollama-cloud-api-key
OLLAMA_EMBEDDING_MODEL=bge-m3

# =============================================================================
# OLLAMA LOCAL (Document Processing — fast local model)
# =============================================================================
OLLAMA_LOCAL_HOST=http://localhost:11434
OLLAMA_LOCAL_MODEL=qwen3:14b

# =============================================================================
# EMBEDDING & RETRIEVAL
# =============================================================================
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
EMBEDDING_DIM=1024
EMBEDDING_DEVICE=cpu
RERANKER_MODEL=BAAI/bge-reranker-base
TOPK_DENSE=50
TOPK_RERANK=20
FINAL_CONTEXT_CHUNKS=8
MIN_CONFIDENCE_TO_ANSWER=0.62
RETRIEVAL_SIMILARITY_THRESHOLD=0.10

# =============================================================================
# RAG PIPELINE
# =============================================================================
RAG_V3_ENABLED=true
RETRIEVAL_CHUNK_SIZE=800
RETRIEVAL_CHUNK_OVERLAP=200
MAX_CONTEXT_TOKENS=4096
MAX_CONTEXT_CHARS=14000

# =============================================================================
# LLM SETTINGS
# =============================================================================
LLM_TEMPERATURE=0.2
LLM_TOP_P=0.85
LLM_MAX_TOKENS=2048
LLM_DISABLE_EXTERNAL=true
LLM_MAX_CONCURRENCY=8

# =============================================================================
# vLLM INFERENCE ENGINE
# =============================================================================
VLLM_ENABLED=true
VLLM_ENDPOINT=http://localhost:8001/v1/chat/completions
VLLM_MODEL_NAME=Qwen/Qwen3-14B-AWQ
VLLM_API_KEY=
VLLM_TIMEOUT=30

# =============================================================================
# FEATURE FLAGS
# =============================================================================
MULTI_AGENT_ENABLED=false
EVIDENCE_SYNTHESIZER_ENABLED=false
VERIFICATION_ENABLED=false
DOC_PROFILER_ENABLED=true
DWX_REASONING_ENGINE_ENABLED=true
DWX_REASONING_FAST_PATH=true
DWX_VERIFY_CONFIDENCE_THRESHOLD=0.8

# =============================================================================
# OBSERVABILITY
# =============================================================================
OBSERVABILITY_LOG_LEVEL=INFO
JSON_LOGGING=true
LOG_DIR=logs
OBSERVABILITY_INCLUDE_CORRELATION_ID=true
